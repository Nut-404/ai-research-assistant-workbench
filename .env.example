OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_PROVIDER=auto
EMBEDDING_MODEL=text-embedding-3-small

APP_NAME=AI Chat Assistant
DATABASE_PATH=./data/ai_chat.sqlite3
